# ── Django ────────────────────────────────────────────────
DEBUG=True
SECRET_KEY=your-secret-key-here-generate-with-python-secrets
DJANGO_SETTINGS_MODULE=bookings_saas.settings.dev

# ── Base de datos ─────────────────────────────────────────
# Opción 1 — URL completa (Railway lo provee automático en producción)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bookings_db

# Opción 2 — Variables individuales (si no usas DATABASE_URL)
# DB_NAME=bookings_db
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=localhost
# DB_PORT=5432

# ── Hosts & CORS ──────────────────────────────────────────
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Frontend ──────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Notificaciones WhatsApp ───────────────────────────────
# CallMeBot (gratuito): https://www.callmebot.com/blog/free-api-whatsapp-messages/
CALLMEBOT_API_KEY=your-callmebot-api-key

# Meta Cloud API (alternativa pro — opcional)
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_ID=
